# МойСклад — токен для API (обязательно)
MS_TOKEN=your_ms_token_here

# Wildberries — токен для API (опционально, для интеграции с WB)
WB_TOKEN=your_wb_token_here

# Ozon — Client ID и API ключ (опционально, для интеграции с Ozon)
OZON_CLIENT_ID=your_ozon_client_id
OZON_API_KEY=your_ozon_api_key

# GitHub — токен для авто-push (опционально)
GH_TOKEN=your_github_token_here
