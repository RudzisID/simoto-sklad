{
  "name": "payment-module",
  "version": "1.0.6",
  "description": "Модуль создания входящих платежей для МойСклад",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "jest",
    "docs": "node scripts/docs-generator.js",
    "push": "node scripts/auto-push.js",
    "push:minor": "node scripts/auto-push.js minor",
    "push:major": "node scripts/auto-push.js major",
    "push:auto": "node scripts/auto-push.js auto",
    "precommit": "npm run docs && npm test",
    "prepublishOnly": "npm run precommit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "moysklad": "^0.21.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "jest": "^29.0.0"
  },
  "simoto": {
    "autoDocs": true,
    "docsDir": "docs",
    "autoUpdate": "oncommit",
    "modules": "lib"
  }
}
