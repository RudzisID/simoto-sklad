{
  "name": "simoto-sklad",
  "version": "1.8.24",
  "description": "Модуль автоматизации платежей и управления заказами для МойСклад",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "lint:fix": "eslint . --fix",
    "docs": "node scripts/docs-generator.js",
    "push": "node scripts/auto-push.js",
    "push:minor": "node scripts/auto-push.js minor",
    "push:major": "node scripts/auto-push.js major",
    "push:auto": "node scripts/auto-push.js auto",
    "precommit": "npm run format && npm run lint:fix",
    "prepublishOnly": "npm run precommit"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jszip": "^3.10.1",
    "moysklad": "^0.21.1",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jest": "^29.0.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2"
  },
  "simoto": {
    "autoDocs": true,
    "docsDir": "docs",
    "autoUpdate": "oncommit",
    "modules": "lib"
  }
}
